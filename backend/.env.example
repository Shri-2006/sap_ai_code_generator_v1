# ─── SAP AI Core credentials ─────────────────────────────────────────────
# OAuth token endpoint (from SAP BTP service key)
SAP_AUTH_URL=https://your-subaccount.authentication.eu10.hana.ondemand.com/oauth/token
#at the end of sap_auth_url, you need /oauth/token
#so if it ends with ondemand.com, just add the /oauth/token to the end

# OAuth client credentials
SAP_CLIENT_ID=sb-your-client-id
SAP_CLIENT_SECRET=your-client-secret

# AI Core base URL (from service key: serviceurls.AI_API_URL)
SAP_AI_CORE_BASE_URL=https://api.ai.prod.eu-central-1.aws.ml.hana.ondemand.com

# Deployment ID for your Claude model deployment in AI Core
SAP_DEPLOYMENT_ID=your-deployment-id

# Resource group (usually "default" unless you created a custom one)
SAP_RESOURCE_GROUP=default

# ─── Server ───────────────────────────────────────────────────────────────
PORT=3000
